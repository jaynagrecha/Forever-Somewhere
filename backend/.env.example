# Backend environment — copy to backend/.env

DATABASE_URL=sqlite:///./forever_somewhere.db
UPLOAD_DIR=uploads

# Comma-separated frontend URLs (add your Vercel URL after deploy)
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Optional: Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Apple Web Push requires a real https:// URL or mailto: with a valid domain (not .local / @localhost)
VAPID_CLAIMS_EMAIL=https://forever-somewhere-web.onrender.com

# Account recovery emails (Resend — https://resend.com)
# Use onboarding@resend.dev for testing; verify your domain for production.
RESEND_API_KEY=
RECOVERY_FROM_EMAIL=Forever Somewhere <onboarding@resend.dev>
RECOVERY_OTP_TTL_MINUTES=15
