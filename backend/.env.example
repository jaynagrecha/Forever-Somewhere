# Backend environment — copy to backend/.env

DATABASE_URL=sqlite:///./forever_somewhere.db
UPLOAD_DIR=uploads

# Comma-separated frontend URLs (add your Vercel URL after deploy)
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Optional: Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Apple Web Push requires a real https:// URL or mailto: with a valid domain (not .local / @localhost)
VAPID_CLAIMS_EMAIL=https://forever-somewhere-web.onrender.com

# Account recovery OTP emails
RECOVERY_OTP_TTL_MINUTES=15
RECOVERY_FROM_EMAIL=Forever Somewhere <you@gmail.com>

# Recommended: Gmail SMTP — delivers OTP to ANY email (both partners).
# Create an App Password: Google Account → Security → 2-Step Verification → App passwords
EMAIL_PROVIDER=auto
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_USE_TLS=true

# Alternative: Resend (https://resend.com) — requires a verified domain to email anyone
# other than your Resend signup address when using onboarding@resend.dev
RESEND_API_KEY=
