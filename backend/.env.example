# Backend environment — copy to backend/.env

DATABASE_URL=sqlite:///./forever_somewhere.db
UPLOAD_DIR=uploads

# Comma-separated frontend URLs
CORS_ORIGINS=http://localhost:5173,https://forever-somewhere-web.onrender.com

# Optional: Web Push (auto-generated on Render disk if unset)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=https://forever-somewhere-web.onrender.com

# Account recovery OTP emails (Gmail SMTP)
RECOVERY_OTP_TTL_MINUTES=15
RECOVERY_FROM_EMAIL=Forever Somewhere <you@gmail.com>
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_USE_TLS=true
